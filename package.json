{
  "name": "parsimony",
  "version": "1.0.0",
  "description": "River Romney's cross-site design token system",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/build-brands.mjs",
    "docs": "node scripts/generate-docs.mjs",
    "build:all": "node scripts/build-brands.mjs && node scripts/generate-docs.mjs",
    "validate": "node scripts/validate.mjs",
    "lint:stories": "node scripts/lint-stories.mjs",
    "build:cem": "npm run cem --workspace @riverromney/components && node scripts/normalize-cem.mjs",
    "build:meta": "npm run build:cem && node scripts/build-design-system-json.mjs && node scripts/build-considerations.mjs",
    "build:considerations": "node scripts/build-considerations.mjs",
    "drift": "node scripts/drift-lint.mjs",
    "check:publish-fresh": "node scripts/check-publish-fresh.mjs",
    "test": "npm test --workspaces --if-present"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "style-dictionary": "^4.0.0"
  }
}
