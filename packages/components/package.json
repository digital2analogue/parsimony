{
  "name": "@digital2analogue2/parsimony-components",
  "version": "0.1.0",
  "description": "Framework-agnostic Lit web components for the River Romney design system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cem": "cem analyze --litelement",
    "figma:connect": "figma connect publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "story-ui": "story-ui start",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "lit": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@figma/code-connect": "^1.4.9",
    "@playwright/test": "^1.49.0",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/web-components-vite": "^10.5.2",
    "@tpitre/story-ui": "^4.16.12",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "lit": "^3.2.0",
    "storybook": "^10.4.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.9",
    "vitest-axe": "^1.0.0-pre.3"
  },
  "customElements": "custom-elements.json",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "custom-elements.json",
    "src/react.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/digital2analogue/parsimony.git",
    "directory": "packages/components"
  }
}
