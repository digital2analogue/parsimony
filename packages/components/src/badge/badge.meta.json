    "--component-badge-danger-border",
    "--component-badge-info-background",
    "--component-badge-info-foreground",
    "--component-badge-info-border",
    "--component-badge-accent-green-background",
    "--component-badge-accent-green-foreground",
    "--component-badge-accent-green-border",
    "--component-badge-accent-blue-background",
