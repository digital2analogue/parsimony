    "--component-badge-radius",
    "--component-badge-padding-x",
    "--component-badge-padding-y",
    "--font-label-small"
  ],
  "rules": [
    "Never use hex values. Always use var(--color-*) or var(--component-*)",
    "Never reference --primitive-* tokens in component code",
    "All text/background pairings must pass WCAG AA (4.5:1)",
    "Variants use a subtle style: a tinted background with accent-colored text, not a solid fill. component-badge-{variant}-foreground is the accent color itself (e.g. foreground-success), not foreground-on-{variant}.",
    "To make a variant solid instead (bright fill + dark text), repoint its component tokens to background-{variant} and foreground-on-{variant}; consumer code does not change."
  ],
  "examples": [
    {
      "title": "Default",
      "html": "<rr-badge>Label</rr-badge>"
    },
    {
      "title": "Success",
      "html": "<rr-badge variant=\"success\">Active</rr-badge>"
    },
    {
      "title": "Warning",
      "html": "<rr-badge variant=\"warning\">Pending</rr-badge>"
    },
    {
      "title": "Danger",
      "html": "<rr-badge variant=\"danger\">Error</rr-badge>"
    },
    {
      "title": "Info",
      "html": "<rr-badge variant=\"info\">In Review</rr-badge>"
    },
    {
      "title": "Accent chips",
      "html": "<rr-badge variant=\"accent-green\">Tag</rr-badge>\n<rr-badge variant=\"accent-blue\">Category</rr-badge>\n<rr-badge variant=\"accent-violet\">Feature</rr-badge>\n<rr-badge variant=\"accent-amber\">New</rr-badge>"
    },
    {
      "title": "Live region",
      "html": "<rr-badge variant=\"success\" role=\"status\">Connected</rr-badge>"
