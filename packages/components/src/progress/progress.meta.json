{
  "metaVersion": "1.0.0",
  "status": "beta",
  "name": "rr-progress",
  "summary": "Horizontal progress bar with determinate and indeterminate modes, using native role=\"progressbar\".",
  "package": "@riverromney/components",
  "props": [
    { "name": "value", "type": "number", "default": "0" },
    { "name": "max", "type": "number", "default": "100" },
    { "name": "indeterminate", "type": "boolean", "default": "false" },
    { "name": "label", "type": "string", "default": "" }
  ],
  "slots": [],
  "events": [],
  "cssParts": [],
  "tokensUsed": [
    "--radius-full",
    "--color-background-disabled",
    "--color-background-action",
    "--motion-duration-standard",
    "--motion-easing-move"
  ],
  "rules": [
    "Never use hex values — always var(--color-*) or var(--component-*)",
    "Never reference --primitive-* tokens in component code",
    "All text/background pairings must pass WCAG AA (4.5:1)",
    "Always provide a label (or an external visible label) so the progressbar has an accessible name"
  ],
  "examples": [
    { "title": "Determinate progress", "html": "<rr-progress value=\"60\" max=\"100\" label=\"Upload progress\"></rr-progress>" },
    { "title": "Indeterminate loading", "html": "<rr-progress indeterminate label=\"Loading…\"></rr-progress>" },
    { "title": "Custom max", "html": "<rr-progress value=\"50\" max=\"200\" label=\"Sync progress\"></rr-progress>" }
  ],
  "accessibility": {
    "ariaPattern": "https://www.w3.org/WAI/ARIA/apg/",
    "role": "progressbar",
    "focusable": false,
    "keyboard": [],
    "wcag": [
      "1.4.3 Contrast (Minimum)",
      "4.1.2 Name, Role, Value"
    ],
    "rules": [
      "aria-valuenow is omitted and aria-busy=\"true\" is set in indeterminate mode",
      "aria-valuemin is always 0 and aria-valuemax tracks the max prop"
    ]
