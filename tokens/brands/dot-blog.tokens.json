{
  "$description": "riverromney.blog overrides — long-form reading",
  "font": {
    "body": {
      "large": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{font.family.serif}",
          "fontWeight": "{primitive.font.weight.regular}",
          "fontSize": "18px",
          "lineHeight": "{primitive.font.lineHeight.relaxed}"
        },
        "$description": "Larger default body for long-form reading. Overrides base body.large from 16px/1.6 to 18px/1.7. body.medium and body.small inherit from base."
      }
    }
  }
}
